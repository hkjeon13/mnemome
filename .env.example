MNEMOME_ENV=development
MNEMOME_STORAGE_BACKEND=sqlite
MNEMOME_DATABASE_PATH=/data/mnemome.db
MNEMOME_DATABASE_URL=
MNEMOME_DB_POOL_MIN_SIZE=1
MNEMOME_DB_POOL_MAX_SIZE=10
MNEMOME_DB_COMMAND_TIMEOUT_S=5
MNEMOME_VALKEY_URL=
MNEMOME_VALKEY_PREFIX=mnemome:v1
MNEMOME_RECALL_CACHE_TTL_S=60
MNEMOME_API_KEYS={"local-development-key":{"tenant_id":"local","principal_id":"developer","roles":["admin","agent","memory:read","memory:write"]}}
MNEMOME_TENANT_DELEGATION_SECRET=
MNEMOME_TENANT_DELEGATION_MAX_SKEW_S=60
MNEMOME_LOG_LEVEL=INFO
MNEMOME_REQUIRE_LOTTE_AGENT=0
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4.1-mini
OPENAI_BASE_URL=https://api.openai.com/v1
MNEMOME_MCP_URL=https://assistant.fin-ally.net/mcp
MNEMOME_MCP_TOOL_ALLOWLIST=sandbox_python_execute,search_retrieve,search_detail,company_search,stock_price,market_data,company_analysis
